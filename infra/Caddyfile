{$DOMAIN} {
    # MinIO presigned PUT/GET uploads — must be reachable by browsers.
    # The /storage prefix is stripped before forwarding to MinIO.
    handle /storage/* {
        uri strip_prefix /storage
        reverse_proxy minio:9000 {
            # Presigned URLs are signed with Host: minio:9000. Override the
            # incoming browser Host header so MinIO's signature check passes.
            header_up Host minio:9000
        }
    }

    handle {
        reverse_proxy web:3000
    }

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
        -Server
    }

    encode gzip zstd

    log {
        output stdout
        format json
        level INFO
    }
}
