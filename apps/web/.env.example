# Application
NODE_ENV=production

# Database (PostgreSQL 18)
# Use service name "postgres" when running via docker-compose; use "localhost" for local dev outside Docker
DATABASE_URL="postgresql://schmittnet:schmittnet@postgres:5432/schmittnet_dev"
POSTGRES_USER=schmittnet
POSTGRES_PASSWORD=schmittnet
POSTGRES_DB=schmittnet_dev

# Redis
# Use service name "redis" when running via docker-compose; use "localhost" for local dev outside Docker
REDIS_URL="redis://redis:6379"

# MinIO (S3-compatible object storage)
# MINIO_ROOT_USER / MINIO_ROOT_PASSWORD are used by the MinIO server itself (set via env_file).
# MINIO_ACCESS_KEY / MINIO_SECRET_KEY are the same credentials used by the app SDK.
# Use service name "minio" when running via docker-compose; use "localhost" for local dev outside Docker
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=tickets
# Public URL that browsers use for presigned PUT/GET requests.
# Must match the path/subdomain Caddy proxies to minio:9000.
# Example: https://yourdomain.com/storage
MINIO_PUBLIC_URL=https://yourdomain.com/storage

# Public-facing base URL — used to build ticket links in Discord notifications (optional)
APP_URL=https://yourdomain.com

# Email notifications (Gmail SMTP)
GMAIL_USER=your-gmail@gmail.com
GMAIL_APP_PASSWORD=your-gmail-app-password

# Error tracking (optional)
SENTRY_DSN=

# Domain (production only)
DOMAIN=yourdomain.com
