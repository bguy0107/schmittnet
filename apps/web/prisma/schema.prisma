generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  OWNER
  OWNER_STAFF
  TECHNICIAN
}

enum Category {
  IT
  MAINTENANCE
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  ON_HOLD
  AWAITING_APPROVAL
  APPROVED
  RESOLVED
  CANCELLED
}

enum Priority {
  P0
  P1
  P2
  NORMAL
}

enum MediaType {
  PHOTO
  VIDEO
}

enum ApprovalStatus {
  PENDING
  APPROVED
  DECLINED
}

enum HistoryEntryType {
  NOTE
  STATUS_CHANGE
  DEADLINE_CHANGE
}

// ─── Sessions (ADR-006) ───────────────────────────────────────────────────────

// Server-side sessions: an opaque random token lives in an HttpOnly cookie, and
// only its SHA-256 hash is stored here as `sessionToken` — a DB read alone can't
// forge or replay a session. Deleting the row revokes it instantly (see
// src/lib/session.ts), unlike a JWT which stays valid until it expires.
model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// ─── Application models ───────────────────────────────────────────────────────

model Owner {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  locations Location[]
  users     User[]

  @@map("owners")
}

model User {
  id                  String     @id @default(uuid())
  email               String     @unique
  name                String?
  // emailVerified/image are vestigial from the removed Auth.js adapter — unused,
  // kept nullable so dropping them later needs no backfill.
  emailVerified       DateTime?  @map("email_verified")
  image               String?
  role                Role
  categories          Category[]
  notificationEmail   Boolean    @default(false) @map("notification_email")
  ownerId             String?    @map("owner_id")
  passwordHash        String     @map("password_hash")
  isActive            Boolean    @default(true) @map("is_active")
  lastLoginAt         DateTime?  @map("last_login_at")
  createdAt           DateTime   @default(now()) @map("created_at")
  updatedAt           DateTime   @updatedAt @map("updated_at")

  owner              Owner?           @relation(fields: [ownerId], references: [id])
  sessions           Session[]
  assignedTickets    Ticket[]         @relation("AssignedTechnician")
  history            TicketHistory[]
  approvalsRequested TicketApproval[] @relation("RequestedBy")
  approvalsActioned  TicketApproval[] @relation("ActionedBy")

  @@map("users")
}

model Location {
  id        String   @id @default(uuid())
  name      String
  ownerId   String   @map("owner_id")
  qrToken   String   @unique @map("qr_token")
  qrActive  Boolean  @default(true) @map("qr_active")
  address   String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  owner   Owner    @relation(fields: [ownerId], references: [id])
  tickets Ticket[]

  @@map("locations")
}

model Ticket {
  id             String       @id @default(uuid())
  locationId     String       @map("location_id")
  category       Category
  description    String
  status         TicketStatus @default(OPEN)
  deadline       DateTime?
  assignedTo     String?      @map("assigned_to")
  priority       Priority     @default(NORMAL)
  acknowledgedAt DateTime?    @map("acknowledged_at")
  onHoldReason   String?      @map("on_hold_reason")
  resolvedAt     DateTime?    @map("resolved_at")
  reporterName   String?      @map("reporter_name")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  location  Location         @relation(fields: [locationId], references: [id])
  assignee  User?            @relation("AssignedTechnician", fields: [assignedTo], references: [id])
  media     TicketMedia[]
  history   TicketHistory[]
  approvals TicketApproval[]

  @@map("tickets")
}

model TicketMedia {
  id         String    @id @default(uuid())
  ticketId   String    @map("ticket_id")
  storageKey String    @map("storage_key")
  mediaType  MediaType @map("media_type")
  mimeType   String    @map("mime_type")
  createdAt  DateTime  @default(now()) @map("created_at")

  ticket Ticket @relation(fields: [ticketId], references: [id])

  @@map("ticket_media")
}

model TicketHistory {
  id         String           @id @default(uuid())
  ticketId   String           @map("ticket_id")
  authorId   String?          @map("author_id")
  authorName String?          @map("author_name")
  type       HistoryEntryType @default(NOTE)
  content    String?
  fromStatus TicketStatus?    @map("from_status")
  toStatus   TicketStatus?    @map("to_status")
  createdAt  DateTime         @default(now()) @map("created_at")
  seq        Int              @default(autoincrement()) @map("seq")

  ticket Ticket @relation(fields: [ticketId], references: [id])
  author User?  @relation(fields: [authorId], references: [id])

  @@map("ticket_history")
}

model TicketApproval {
  id             String         @id @default(uuid())
  ticketId       String         @map("ticket_id")
  requestedBy    String         @map("requested_by")
  approverId     String?        @map("approver_id")
  status         ApprovalStatus @default(PENDING)
  approvalReason String?        @map("approval_reason")
  notes          String?
  createdAt      DateTime       @default(now()) @map("created_at")
  resolvedAt     DateTime?      @map("resolved_at")

  ticket    Ticket @relation(fields: [ticketId], references: [id])
  requester User   @relation("RequestedBy", fields: [requestedBy], references: [id])
  approver  User?  @relation("ActionedBy", fields: [approverId], references: [id])

  @@map("ticket_approvals")
}


model Setting {
  key   String @id
  value String

  @@map("settings")
}
